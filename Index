import React, { useState, useEffect, useMemo } from 'react';
import { initializeApp } from 'firebase/app';
import { 
  getFirestore, collection, addDoc, onSnapshot, 
  deleteDoc, doc, serverTimestamp, query, orderBy, getDocs
} from 'firebase/firestore';
import { 
  getAuth, signInAnonymously, signInWithCustomToken, onAuthStateChanged 
} from 'firebase/auth';
import { 
  LineChart, Line, XAxis, YAxis, CartesianGrid, 
  Tooltip, ResponsiveContainer, BarChart, Bar, Cell, Legend 
} from 'recharts';
import { 
  Plus, Trash2, Users, Settings, Award, 
  History, LayoutDashboard, ChevronRight, UserPlus, 
  AlertCircle, CheckCircle, Info, Calendar
} from 'lucide-react';

// --- FIREBASE CONFIGURATION ---
// Use environment variables for the preview environment to prevent API key errors
const firebaseConfig = typeof __firebase_config !== 'undefined' 
  ? JSON.parse(__firebase_config) 
  : {
      apiKey: "AIzaSyDVxpbThTvMCZR8tkbqVvUbhAKGTmSkl_g",
      authDomain: "employee-dashboard-2.firebaseapp.com",
      projectId: "employee-dashboard-2",
      storageBucket: "employee-dashboard-2.firebasestorage.app",
      messagingSenderId: "986398601231",
      appId: "1:986398601231:web:1a6d9c9b171ea8236337a"
    };

const app = initializeApp(firebaseConfig);
const auth = getAuth(app);
const db = getFirestore(app);
const appId = typeof __app_id !== 'undefined' ? __app_id : 'employee-dashboard-prod';

// --- UTILS ---
const formatMonthKey = (date = new Date()) => {
  return `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, '0')}`;
};

const getMonthDisplay = (key) => {
  if (!key) return '';
  const [year, month] = key.split('-');
  return new Date(year, month - 1).toLocaleString('default', { month: 'long', year: 'numeric' });
};

export default function App() {
  const [user, setUser] = useState(null);
  const [activeTab, setActiveTab] = useState('dashboard');
  const [employees, setEmployees] = useState([]);
  const [reasons, setReasons] = useState([]);
  const [points, setPoints] = useState([]);
  const [logs, setLogs] = useState([]);
  const [selectedMonth, setSelectedMonth] = useState(formatMonthKey());
  const [selectedEmployeeId, setSelectedEmployeeId] = useState(null);

  // Form States
  const [empForm, setEmpForm] = useState("");
  const [reasonForm, setReasonForm] = useState({ text: "", value: 0 });
  const [pointForm, setPointForm] = useState({ empId: "", reasonId: "", admin: "", notes: "" });

  // 1. Auth Initialization (Mandatory Rule 3)
  useEffect(() => {
    const initAuth = async () => {
      try {
        if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
          await signInWithCustomToken(auth, __initial_auth_token);
        } else {
          await signInAnonymously(auth);
        }
      } catch (err) {
        console.error("Auth Error", err);
      }
    };
    initAuth();
    const unsubscribe = onAuthStateChanged(auth, setUser);
    return () => unsubscribe();
  }, []);

  // 2. Data Subscriptions (Rules 1 & 2)
  useEffect(() => {
    if (!user) return;

    // Strict Path adherence (Rule 1)
    const getPath = (coll) => collection(db, 'artifacts', appId, 'public', 'data', coll);

    const unsubEmp = onSnapshot(getPath('employees'), (snap) => {
      setEmployees(snap.docs.map(d => ({ id: d.id, ...d.data() })));
    }, (err) => console.error("Firestore Error (Employees):", err));

    const unsubReason = onSnapshot(getPath('reasons'), (snap) => {
      setReasons(snap.docs.map(d => ({ id: d.id, ...d.data() })));
    }, (err) => console.error("Firestore Error (Reasons):", err));

    const unsubPoints = onSnapshot(getPath('points'), (snap) => {
      const data = snap.docs.map(d => ({ id: d.id, ...d.data() }));
      // Filter/Sort in JS (Rule 2)
      data.sort((a, b) => (b.timestamp?.seconds || 0) - (a.timestamp?.seconds || 0));
      setPoints(data);
    }, (err) => console.error("Firestore Error (Points):", err));

    const unsubLogs = onSnapshot(getPath('change_logs'), (snap) => {
      const data = snap.docs.map(d => ({ id: d.id, ...d.data() }));
      data.sort((a, b) => (b.timestamp?.seconds || 0) - (a.timestamp?.seconds || 0));
      setLogs(data);
    }, (err) => console.error("Firestore Error (Logs):", err));

    return () => {
      unsubEmp();
      unsubReason();
      unsubPoints();
      unsubLogs();
    };
  }, [user]);

  // 3. Actions
  const logAction = async (action, details, admin) => {
    if (!user) return;
    await addDoc(collection(db, 'artifacts', appId, 'public', 'data', 'change_logs'), {
      action,
      details,
      admin: admin || "System",
      timestamp: serverTimestamp()
    });
  };

  const addEmployee = async (e) => {
    e.preventDefault();
    if (!user || !empForm.trim()) return;
    await addDoc(collection(db, 'artifacts', appId, 'public', 'data', 'employees'), { 
      name: empForm.trim(),
      createdAt: serverTimestamp()
    });
    await logAction("Employee Added", `Added new employee: ${empForm}`, "Admin");
    setEmpForm("");
  };

  const removeEmployee = async (id, name) => {
    if (!user) return;
    await deleteDoc(doc(db, 'artifacts', appId, 'public', 'data', 'employees', id));
    await logAction("Employee Removed", `Removed employee: ${name}`, "Admin");
  };

  const addReason = async (e) => {
    e.preventDefault();
    if (!user || !reasonForm.text.trim()) return;
    await addDoc(collection(db, 'artifacts', appId, 'public', 'data', 'reasons'), {
      ...reasonForm,
      value: Number(reasonForm.value)
    });
    await logAction("Reason Added", `New logic: ${reasonForm.text} (${reasonForm.value} pts)`, "Admin");
    setReasonForm({ text: "", value: 0 });
  };

  const removeReason = async (id, text) => {
    if (!user) return;
    await deleteDoc(doc(db, 'artifacts', appId, 'public', 'data', 'reasons', id));
    await logAction("Reason Removed", `Deleted reason: ${text}`, "Admin");
  };

  const assignPoint = async (e) => {
    e.preventDefault();
    if (!user) return;
    const emp = employees.find(e => e.id === pointForm.empId);
    const reas = reasons.find(r => r.id === pointForm.reasonId);
    if (!emp || !reas) return;

    await addDoc(collection(db, 'artifacts', appId, 'public', 'data', 'points'), {
      employeeId: emp.id,
      employeeName: emp.name,
      reasonId: reas.id,
      reasonText: reas.text,
      value: Number(reas.value),
      admin: pointForm.admin,
      notes: pointForm.notes,
      monthKey: formatMonthKey(),
      timestamp: serverTimestamp()
    });

    await logAction("Points Assigned", `${reas.value > 0 ? '+' : ''}${reas.value} assigned to ${emp.name} for "${reas.text}"`, pointForm.admin);
    setPointForm({ empId: "", reasonId: "", admin: pointForm.admin, notes: "" });
  };

  const deletePointEntry = async (point) => {
    if (!user) return;
    await deleteDoc(doc(db, 'artifacts', appId, 'public', 'data', 'points', point.id));
    await logAction("Points Reverted", `Removed ${point.value} pts from ${point.employeeName} (${point.reasonText})`, "Admin");
  };

  // 4. Computed Data
  const leaderboardData = useMemo(() => {
    const totals = {};
    employees.forEach(e => totals[e.id] = { name: e.name, score: 0 });
    
    points
      .filter(p => p.monthKey === selectedMonth)
      .forEach(p => {
        if (totals[p.employeeId]) totals[p.employeeId].score += p.value;
      });

    return Object.values(totals).sort((a, b) => b.score - a.score);
  }, [employees, points, selectedMonth]);

  const employeeTrends = useMemo(() => {
    if (!selectedEmployeeId) return [];
    
    const daily = {};
    points
      .filter(p => p.employeeId === selectedEmployeeId)
      .forEach(p => {
        if (!p.timestamp) return;
        const dateStr = p.timestamp.toDate().toLocaleDateString();
        if (!daily[dateStr]) daily[dateStr] = { date: dateStr, pos: 0, neg: 0, total: 0 };
        if (p.value > 0) daily[dateStr].pos += p.value;
        else daily[dateStr].neg += Math.abs(p.value);
        daily[dateStr].total += p.value;
      });

    return Object.values(daily).reverse();
  }, [points, selectedEmployeeId]);

  const stats = useMemo(() => {
    const monthPoints = points.filter(p => p.monthKey === selectedMonth);
    const positive = monthPoints.filter(p => p.value > 0).reduce((acc, curr) => acc + curr.value, 0);
    const negative = monthPoints.filter(p => p.value < 0).reduce((acc, curr) => acc + curr.value, 0);
    return { positive, negative, total: monthPoints.length };
  }, [points, selectedMonth]);

  const SidebarItem = ({ id, icon: Icon, label }) => (
    <button 
      onClick={() => setActiveTab(id)}
      className={`w-full flex items-center gap-3 p-3 px-4 rounded-lg transition-all ${activeTab === id ? 'bg-indigo-600 text-white shadow-lg shadow-indigo-200' : 'text-gray-500 hover:bg-gray-100'}`}
    >
      <Icon size={20} />
      <span className="font-medium">{label}</span>
    </button>
  );

  return (
    <div className="flex h-screen bg-gray-50 overflow-hidden">
      {/* Sidebar */}
      <aside className="w-64 bg-white border-r flex flex-col p-6 shrink-0">
        <div className="flex items-center gap-3 mb-10 px-2">
          <div className="w-10 h-10 bg-indigo-600 rounded-xl flex items-center justify-center text-white">
            <Award size={24} />
          </div>
          <span className="text-xl font-bold tracking-tight text-gray-800">TeamPulse</span>
        </div>

        <nav className="flex-1 space-y-2">
          <SidebarItem id="dashboard" icon={LayoutDashboard} label="Dashboard" />
          <SidebarItem id="assign" icon={Plus} label="Assign Points" />
          <SidebarItem id="team" icon={Users} label="Team Management" />
          <SidebarItem id="settings" icon={Settings} label="System Config" />
          <SidebarItem id="changelog" icon={History} label="Change Log" />
        </nav>

        <div className="mt-auto pt-6 border-t">
          <div className="flex items-center gap-3 px-2">
            <div className="w-8 h-8 rounded-full bg-gray-200 flex items-center justify-center text-xs font-bold text-gray-600 uppercase">
              {pointForm.admin ? pointForm.admin[0] : 'A'}
            </div>
            <div className="overflow-hidden">
              <p className="text-sm font-semibold text-gray-700 truncate">{pointForm.admin || "Admin"}</p>
              <p className="text-xs text-gray-400">Project Owner</p>
            </div>
          </div>
        </div>
      </aside>

      {/* Main Content */}
      <main className="flex-1 overflow-y-auto p-8 pt-6">
        <header className="flex justify-between items-center mb-8">
          <div>
            <h1 className="text-2xl font-bold text-gray-900 capitalize">{activeTab.replace('_', ' ')}</h1>
            <p className="text-gray-500 text-sm">Managing team engagement and performance</p>
          </div>
          <div className="flex items-center gap-4 bg-white p-2 px-3 rounded-xl border shadow-sm">
            <Calendar size={18} className="text-indigo-500" />
            <select 
              className="bg-transparent border-none focus:ring-0 text-sm font-medium text-gray-700 cursor-pointer"
              value={selectedMonth}
              onChange={e => setSelectedMonth(e.target.value)}
            >
              {[0, 1, 2, 3, 4, 5].map(i => {
                const d = new Date();
                d.setDate(1); 
                d.setMonth(d.getMonth() - i);
                const key = formatMonthKey(d);
                return <option key={key} value={key}>{getMonthDisplay(key)}</option>;
              })}
            </select>
          </div>
        </header>

        {!user ? (
          <div className="flex items-center justify-center h-[60vh] flex-col gap-4">
             <div className="animate-spin rounded-full h-12 w-12 border-b-2 border-indigo-600"></div>
             <p className="text-gray-500 font-medium">Authenticating system...</p>
          </div>
        ) : (
          <>
            {activeTab === 'dashboard' && (
              <div className="space-y-8 animate-in fade-in slide-in-from-bottom-4 duration-500">
                <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
                  <div className="bg-white p-6 rounded-2xl border shadow-sm">
                    <div className="flex justify-between items-start mb-4">
                      <div className="p-2 bg-green-50 text-green-600 rounded-lg"><CheckCircle size={24} /></div>
                      <span className="text-xs font-medium text-green-600 bg-green-50 px-2 py-1 rounded-full">Monthly</span>
                    </div>
                    <p className="text-gray-500 text-sm font-medium">Positive Interactions</p>
                    <h3 className="text-3xl font-bold text-gray-900 mt-1">+{stats.positive}</h3>
                  </div>
                  <div className="bg-white p-6 rounded-2xl border shadow-sm">
                    <div className="flex justify-between items-start mb-4">
                      <div className="p-2 bg-red-50 text-red-600 rounded-lg"><AlertCircle size={24} /></div>
                      <span className="text-xs font-medium text-red-600 bg-red-50 px-2 py-1 rounded-full">Monthly</span>
                    </div>
                    <p className="text-gray-500 text-sm font-medium">Negative Flags</p>
                    <h3 className="text-3xl font-bold text-gray-900 mt-1">{stats.negative}</h3>
                  </div>
                  <div className="bg-white p-6 rounded-2xl border shadow-sm">
                    <div className="flex justify-between items-start mb-4">
                      <div className="p-2 bg-indigo-50 text-indigo-600 rounded-lg"><Info size={24} /></div>
                      <span className="text-xs font-medium text-indigo-600 bg-indigo-50 px-2 py-1 rounded-full">Total Actions</span>
                    </div>
                    <p className="text-gray-500 text-sm font-medium">System Events</p>
                    <h3 className="text-3xl font-bold text-gray-900 mt-1">{stats.total}</h3>
                  </div>
                </div>

                <div className="bg-white p-8 rounded-2xl border shadow-sm">
                  <h2 className="text-lg font-bold text-gray-800 mb-6 flex items-center gap-2">
                    <Award size={20} className="text-yellow-500" /> Team Leaderboard ({getMonthDisplay(selectedMonth)})
                  </h2>
                  <div className="h-[400px] w-full">
                    <ResponsiveContainer width="100%" height="100%">
                      <BarChart data={leaderboardData} layout="vertical" margin={{ left: 40, right: 40 }}>
                        <CartesianGrid strokeDasharray="3 3" horizontal={false} stroke="#f0f0f0" />
                        <XAxis type="number" hide />
                        <YAxis 
                          dataKey="name" 
                          type="category" 
                          tick={{ fill: '#4b5563', fontSize: 13, fontWeight: 500 }}
                          width={100}
                        />
                        <Tooltip 
                          cursor={{ fill: '#f9fafb' }}
                          contentStyle={{ borderRadius: '12px', border: 'none', boxShadow: '0 10px 15px -3px rgb(0 0 0 / 0.1)' }}
                        />
                        <Bar dataKey="score" radius={[0, 8, 8, 0]} barSize={32}>
                          {leaderboardData.map((entry, index) => (
                            <Cell key={`cell-${index}`} fill={entry.score >= 0 ? '#4f46e5' : '#ef4444'} />
                          ))}
                        </Bar>
                      </BarChart>
                    </ResponsiveContainer>
                  </div>
                </div>
              </div>
            )}

            {activeTab === 'assign' && (
              <div className="max-w-2xl mx-auto space-y-6">
                <div className="bg-white p-8 rounded-2xl border shadow-sm">
                  <form onSubmit={assignPoint} className="space-y-6">
                    <div className="grid grid-cols-2 gap-4">
                      <div className="space-y-2">
                        <label className="text-sm font-semibold text-gray-700">Target Employee</label>
                        <select 
                          className="w-full bg-gray-50 border-gray-200 rounded-xl p-3 focus:ring-2 focus:ring-indigo-500 transition-all"
                          value={pointForm.empId}
                          onChange={e => setPointForm({...pointForm, empId: e.target.value})}
                          required
                        >
                          <option value="">Select Employee...</option>
                          {employees.map(e => <option key={e.id} value={e.id}>{e.name}</option>)}
                        </select>
                      </div>
                      <div className="space-y-2">
                        <label className="text-sm font-semibold text-gray-700">Select Reason</label>
                        <select 
                          className="w-full bg-gray-50 border-gray-200 rounded-xl p-3 focus:ring-2 focus:ring-indigo-500 transition-all"
                          value={pointForm.reasonId}
                          onChange={e => setPointForm({...pointForm, reasonId: e.target.value})}
                          required
                        >
                          <option value="">Select Action...</option>
                          {reasons.map(r => (
                            <option key={r.id} value={r.id}>
                              {r.text} ({r.value > 0 ? '+' : ''}{r.value})
                            </option>
                          ))}
                        </select>
                      </div>
                    </div>

                    <div className="space-y-2">
                      <label className="text-sm font-semibold text-gray-700">Admin Name</label>
                      <input 
                        type="text"
                        placeholder="Enter your name"
                        className="w-full bg-gray-50 border-gray-200 rounded-xl p-3 focus:ring-2 focus:ring-indigo-500"
                        value={pointForm.admin}
                        onChange={e => setPointForm({...pointForm, admin: e.target.value})}
                        required
                      />
                    </div>

                    <div className="space-y-2">
                      <label className="text-sm font-semibold text-gray-700">Notes (Optional)</label>
                      <textarea 
                        placeholder="Context for this interaction..."
                        rows={4}
                        className="w-full bg-gray-50 border-gray-200 rounded-xl p-3 focus:ring-2 focus:ring-indigo-500"
                        value={pointForm.notes}
                        onChange={e => setPointForm({...pointForm, notes: e.target.value})}
                      />
                    </div>

                    <button 
                      type="submit"
                      className="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-4 rounded-xl shadow-lg shadow-indigo-100 transition-all flex items-center justify-center gap-2"
                    >
                      <Plus size={20} /> Assign Points Now
                    </button>
                  </form>
                </div>

                <div className="bg-white rounded-2xl border shadow-sm overflow-hidden">
                  <div className="p-4 bg-gray-50 border-b flex justify-between items-center px-6">
                    <h3 className="font-bold text-gray-700">Audit Trail (Recent Assignments)</h3>
                  </div>
                  <div className="divide-y max-h-[300px] overflow-y-auto">
                    {points.slice(0, 10).map(p => (
                      <div key={p.id} className="p-4 px-6 hover:bg-gray-50 flex justify-between items-center group">
                        <div className="flex items-center gap-4">
                          <div className={`w-10 h-10 rounded-lg flex items-center justify-center font-bold ${p.value >= 0 ? 'bg-green-50 text-green-600' : 'bg-red-50 text-red-600'}`}>
                            {p.value > 0 ? '+' : ''}{p.value}
                          </div>
                          <div>
                            <p className="text-sm font-bold text-gray-800">{p.employeeName}</p>
                            <p className="text-xs text-gray-500 italic">"{p.reasonText}" • {p.admin}</p>
                          </div>
                        </div>
                        <button 
                          onClick={() => deletePointEntry(p)}
                          className="opacity-0 group-hover:opacity-100 p-2 text-red-400 hover:text-red-600 transition-all"
                          title="Revert Points"
                        >
                          <Trash2 size={18} />
                        </button>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            )}

            {activeTab === 'team' && (
              <div className="grid grid-cols-1 xl:grid-cols-3 gap-8">
                <div className="xl:col-span-1 space-y-4">
                  <div className="bg-white p-6 rounded-2xl border shadow-sm">
                    <form onSubmit={addEmployee} className="flex gap-2">
                      <input 
                        type="text" 
                        placeholder="New Employee Name"
                        className="flex-1 bg-gray-50 border-gray-200 rounded-xl p-3 focus:ring-2 focus:ring-indigo-500"
                        value={empForm}
                        onChange={e => setEmpForm(e.target.value)}
                      />
                      <button type="submit" className="bg-indigo-600 text-white p-3 px-4 rounded-xl hover:bg-indigo-700 transition-all">
                        <UserPlus size={20} />
                      </button>
                    </form>
                  </div>

                  <div className="bg-white rounded-2xl border shadow-sm divide-y overflow-hidden">
                    {employees.map(e => (
                      <button 
                        key={e.id}
                        onClick={() => setSelectedEmployeeId(e.id)}
                        className={`w-full text-left p-4 px-6 flex justify-between items-center transition-all ${selectedEmployeeId === e.id ? 'bg-indigo-50 border-l-4 border-indigo-600' : 'hover:bg-gray-50 border-l-4 border-transparent'}`}
                      >
                        <div>
                          <p className="font-bold text-gray-800">{e.name}</p>
                          <p className="text-xs text-gray-500">Joined {e.createdAt?.toDate().toLocaleDateString()}</p>
                        </div>
                        <div className="flex items-center gap-4">
                          <div className="text-right">
                            <p className="text-lg font-black text-indigo-600">
                              {points.filter(p => p.employeeId === e.id).reduce((s, c) => s + c.value, 0)}
                            </p>
                            <p className="text-[10px] uppercase font-bold text-gray-400">Total Pts</p>
                          </div>
                          <ChevronRight size={16} className={selectedEmployeeId === e.id ? 'text-indigo-600' : 'text-gray-300'} />
                        </div>
                      </button>
                    ))}
                  </div>
                </div>

                <div className="xl:col-span-2 space-y-8">
                  {!selectedEmployeeId ? (
                    <div className="h-full bg-white rounded-2xl border border-dashed flex flex-col items-center justify-center text-gray-400 p-12">
                      <Users size={48} className="mb-4 opacity-20" />
                      <p className="font-medium">Select an employee to view their performance trends</p>
                    </div>
                  ) : (
                    <div className="animate-in fade-in zoom-in-95 duration-300">
                      <div className="bg-white p-8 rounded-2xl border shadow-sm relative overflow-hidden mb-6">
                        <div className="absolute top-0 right-0 p-8">
                           <button 
                            onClick={() => {
                              const name = employees.find(e => e.id === selectedEmployeeId)?.name;
                              if (window.confirm(`Permanently remove ${name} from the system?`)) {
                                removeEmployee(selectedEmployeeId, name);
                                setSelectedEmployeeId(null);
                              }
                            }}
                            className="text-gray-300 hover:text-red-500 transition-colors"
                          >
                            <Trash2 size={20} />
                          </button>
                        </div>
                        <div className="flex items-center gap-6 mb-10">
                          <div className="w-20 h-20 bg-indigo-100 text-indigo-600 rounded-3xl flex items-center justify-center text-3xl font-black">
                            {employees.find(e => e.id === selectedEmployeeId)?.name[0]}
                          </div>
                          <div>
                            <h2 className="text-3xl font-black text-gray-900">{employees.find(e => e.id === selectedEmployeeId)?.name}</h2>
                            <p className="text-gray-500 flex items-center gap-2">
                              <CheckCircle size={14} className="text-green-500" /> Active Employee Profile
                            </p>
                          </div>
                        </div>

                        <h3 className="text-sm font-bold text-gray-400 uppercase tracking-widest mb-4">Historical Performance Trend</h3>
                        <div className="h-[300px] w-full">
                          <ResponsiveContainer width="100%" height="100%">
                            <LineChart data={employeeTrends}>
                              <CartesianGrid strokeDasharray="3 3" vertical={false} stroke="#f1f1f1" />
                              <XAxis dataKey="date" tick={{fontSize: 12}} />
                              <YAxis />
                              <Tooltip contentStyle={{ borderRadius: '12px', border: 'none', boxShadow: '0 10px 15px -3px rgb(0 0 0 / 0.1)' }} />
                              <Legend verticalAlign="top" height={36}/>
                              <Line type="monotone" dataKey="total" stroke="#4f46e5" strokeWidth={3} dot={{ r: 4, fill: '#4f46e5' }} activeDot={{ r: 6 }} name="Net Points" />
                              <Line type="monotone" dataKey="pos" stroke="#10b981" strokeWidth={2} strokeDasharray="5 5" name="Positive" />
                              <Line type="monotone" dataKey="neg" stroke="#ef4444" strokeWidth={2} strokeDasharray="5 5" name="Negative Flags" />
                            </LineChart>
                          </ResponsiveContainer>
                        </div>
